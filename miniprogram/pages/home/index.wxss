/* pages/home/index.wxss */

.home-page {
  padding: 24rpx;
  padding-bottom: 240rpx;
}

/* 锅底选择 */
.pot-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #fff 0%, #FFF5E6 100%);
}
.pot-info {
  display: flex;
  align-items: center;
  flex: 1;
}
.pot-emoji {
  font-size: 64rpx;
  margin-right: 20rpx;
}
.pot-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #2C3E50;
}
.pot-desc {
  font-size: 24rpx;
  color: #7F8C8D;
  margin-top: 4rpx;
}
.arrow {
  color: #BDC3C7;
  font-size: 40rpx;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: linear-gradient(135deg, #C0392B 0%, #8B0000 100%);
  color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 20rpx 0;
}
.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.status-num {
  font-size: 48rpx;
  font-weight: 700;
}
.status-label {
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 4rpx;
}
.status-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 计时卡片 */
.timer-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}
.timer-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border-left: 8rpx solid #27AE60;
}
.timer-card.status-over {
  border-left-color: #E74C3C;
  animation: shake 0.5s ease-in-out infinite;
  background: #FFF5F5;
}
.timer-card.status-done,
.timer-card.status-cancelled {
  border-left-color: #BDC3C7;
  opacity: 0.7;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-4rpx); }
  75% { transform: translateX(4rpx); }
}

.timer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.timer-food {
  display: flex;
  align-items: center;
}
.food-emoji {
  font-size: 48rpx;
  margin-right: 16rpx;
}
.food-name {
  font-size: 32rpx;
  font-weight: 600;
}
.food-meta {
  font-size: 22rpx;
  color: #7F8C8D;
}
.timer-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: #E8F5E9;
  color: #27AE60;
}
.timer-status.status-over {
  background: #FFEBEE;
  color: #E74C3C;
  font-weight: 600;
}
.timer-status.status-done,
.timer-status.status-cancelled {
  background: #F5F5F5;
  color: #95A5A6;
}

/* 倒计时大字 */
.timer-countdown {
  text-align: center;
  font-size: 96rpx;
  font-weight: 700;
  color: #C0392B;
  margin: 20rpx 0;
  font-variant-numeric: tabular-nums;
  font-family: 'DIN Alternate', monospace;
}
.timer-countdown.over {
  color: #E74C3C;
  font-size: 56rpx;
  animation: pulse 0.8s infinite;
}
.timer-countdown.done {
  color: #27AE60;
  font-size: 80rpx;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #ECF0F1;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #27AE60 0%, #F39C12 80%, #E74C3C 100%);
  transition: width 1s linear;
}
.progress-fill.over {
  background: #E74C3C;
}

/* 操作按钮 */
.timer-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}
.btn-mini {
  font-size: 26rpx;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  border: none;
  min-height: 56rpx;
  line-height: 36rpx;
}
.btn-mini::after {
  border: none;
}
.btn-cancel {
  background: #F5F5F5;
  color: #7F8C8D;
}
.btn-confirm {
  background: #27AE60;
  color: #fff;
  font-weight: 600;
}
.btn-remove {
  background: #fff;
  color: #BDC3C7;
  border: 2rpx solid #ECF0F1 !important;
}

/* 空状态 */
.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
}
.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}
.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 12rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #95A5A6;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, transparent 0%, #FFF5E6 40%);
  z-index: 10;
}
.btn-add {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(192, 57, 43, 0.4);
}
.bottom-secondary {
  display: flex;
  justify-content: space-around;
  margin-top: 16rpx;
}
.link {
  font-size: 26rpx;
  color: #7F8C8D;
  padding: 10rpx 20rpx;
}
.link.danger {
  color: #E74C3C;
}

/* 到时提醒弹窗 */
.alert-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.alert-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  width: 80%;
  max-width: 600rpx;
  text-align: center;
  animation: popIn 0.3s ease-out;
}
@keyframes popIn {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
.alert-emoji-big {
  font-size: 160rpx;
  margin-bottom: 20rpx;
  animation: bounce 0.6s ease-out infinite alternate;
}
@keyframes bounce {
  from { transform: translateY(0); }
  to { transform: translateY(-10rpx); }
}
.alert-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #C0392B;
  margin-bottom: 12rpx;
}
.alert-subtitle {
  font-size: 28rpx;
  color: #7F8C8D;
  margin-bottom: 32rpx;
}
.alert-actions button {
  width: 100%;
}
