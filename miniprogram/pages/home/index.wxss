/* pages/home/index.wxss */

.home-page {
  padding: 24rpx;
  padding-bottom: 240rpx;
}

/* 锅底选择 */
.pot-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #fff 0%, #FFF5E6 100%);
}
.pot-info {
  display: flex;
  align-items: center;
  flex: 1;
}
.pot-emoji {
  font-size: 64rpx;
  margin-right: 20rpx;
}
.pot-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #2C3E50;
}
.pot-desc {
  font-size: 24rpx;
  color: #7F8C8D;
  margin-top: 4rpx;
}
.arrow {
  color: #BDC3C7;
  font-size: 40rpx;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: linear-gradient(135deg, #C0392B 0%, #8B0000 100%);
  color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 20rpx 0;
}
.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.status-num {
  font-size: 48rpx;
  font-weight: 700;
}
.status-label {
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 4rpx;
}
.status-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* ─── 计时卡片 ───────────────────────────────────────── */
.timer-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

/* 基础卡片 */
.timer-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  border-left: 8rpx solid #27AE60;
  position: relative;
  overflow: hidden;
}

/* 绿色：时间充裕 */
.timer-card.urgency-safe {
  border-left-color: #27AE60;
}
/* 黄色：快到时间 */
.timer-card.urgency-warn {
  border-left-color: #F39C12;
  background: #FFFDF5;
}
/* 红色：到时了 */
.timer-card.status-over {
  border-left-color: #E74C3C;
  background: #FFF8F8;
  animation: shake 0.5s ease-in-out infinite;
}
/* 已完成/已取消 */
.timer-card.status-done,
.timer-card.status-cancelled {
  border-left-color: #D0CFC9;
  opacity: 0.65;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-3rpx); }
  75% { transform: translateX(3rpx); }
}

/* 顶部一行：食材信息 + 倒计时大字 */
.timer-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.timer-food {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}
.food-emoji {
  font-size: 56rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.food-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}
.food-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
  line-height: 1.2;
}

/* 状态胶囊标签 */
.status-tag {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  width: fit-content;
  /* 默认绿色 */
  background: #E8F8F0;
  color: #27AE60;
}
.status-tag.urgency-warn {
  background: #FEF9E7;
  color: #E67E22;
}
.status-tag.status-over {
  background: #FDEDEC;
  color: #E74C3C;
  animation: pulse 0.8s infinite;
}
.status-tag.status-done,
.status-tag.status-cancelled {
  background: #F2F3F4;
  color: #95A5A6;
  font-weight: 400;
}

/* 倒计时大字（右侧） */
.timer-countdown {
  font-size: 72rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
  letter-spacing: -2rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  /* 默认绿色 */
  color: #27AE60;
}
.timer-countdown.urgency-warn {
  color: #F39C12;
}
.timer-countdown.status-over {
  font-size: 56rpx;
  color: #E74C3C;
  animation: pulse 0.8s infinite;
}
.timer-countdown.status-done {
  font-size: 56rpx;
  color: #27AE60;
}
.timer-countdown.status-cancelled {
  font-size: 56rpx;
  color: #BDC3C7;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.45; }
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 10rpx;
  background: #F0F0F0;
  border-radius: 5rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}
.progress-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width 1s linear;
  background: #27AE60;
}
.progress-fill.urgency-warn {
  background: linear-gradient(90deg, #27AE60, #F39C12);
}
.progress-fill.status-over {
  background: #E74C3C;
}

/* 时长元信息 */
.timer-meta {
  margin-bottom: 16rpx;
}
.meta-text {
  font-size: 22rpx;
  color: #95A5A6;
}
.meta-over {
  font-size: 24rpx;
  color: #E74C3C;
  font-weight: 500;
}

/* 操作按钮 */
.timer-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 4rpx;
}
.btn-mini {
  font-size: 26rpx;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  border: none;
  min-height: 60rpx;
  line-height: 36rpx;
  font-weight: 500;
}
.btn-mini::after { border: none; }
.btn-cancel {
  background: #F5F5F5;
  color: #95A5A6;
}
.btn-confirm {
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(39,174,96,0.35);
}
.btn-remove {
  background: #fff;
  color: #BDC3C7;
  border: 1.5rpx solid #E8E8E8 !important;
}

/* 空状态 */
.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
}
.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}
.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 12rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #95A5A6;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255,245,230,0) 0%, #FFF5E6 35%);
  z-index: 10;
}

/* 下菜按钮 - 新设计 */
.btn-add-food {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #E8432D 0%, #C0392B 50%, #8B0000 100%);
  border: none;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(192, 57, 43, 0.45), 0 2rpx 8rpx rgba(0,0,0,0.1);
  padding: 0;
}
.btn-add-food::after { border: none; }
.btn-add-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}
.btn-add-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.bottom-secondary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  gap: 16rpx;
}
.link {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #7F8C8D;
  background: rgba(255,255,255,0.85);
  border: 1.5rpx solid #E0D5C8;
  border-radius: 40rpx;
  padding: 14rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.link.danger {
  color: #C0392B;
  background: rgba(192,57,43,0.06);
  border-color: rgba(192,57,43,0.25);
}
.link.batch-link {
  color: #8B4513;
  background: rgba(139,69,19,0.07);
  border-color: rgba(139,69,19,0.2);
  font-weight: 500;
}

/* 批量模式工具栏 */
.batch-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(192,57,43,0.1);
  border: 2rpx solid rgba(192,57,43,0.15);
}
.batch-info {}
.batch-count {
  font-size: 28rpx;
  color: #C0392B;
  font-weight: 600;
}
.batch-actions {
  display: flex;
  gap: 16rpx;
}
.batch-btn {
  font-size: 26rpx;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-weight: 500;
}
.batch-select-all {
  background: #F5F5F5;
  color: #34495E;
}
.batch-cancel-btn {
  background: #C0392B;
  color: #fff;
}
.batch-cancel-btn.disabled {
  background: #ECB9B4;
}

/* 批量模式下计时卡片样式 */
.timer-card.batch-selectable {
  position: relative;
  cursor: pointer;
}
.timer-card.batch-selected {
  border-left-color: #C0392B !important;
  background: #FFF5F5 !important;
}
.select-check {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  z-index: 2;
}
.check-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid #BDC3C7;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
  transition: all 0.15s;
}
.check-circle.checked {
  background: #C0392B;
  border-color: #C0392B;
}

/* 批量退出按钮 */
.batch-exit-row {
  display: flex;
  justify-content: center;
}
.btn-batch-exit {
  background: #fff;
  color: #C0392B;
  border: 2rpx solid #C0392B;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 80rpx;
}

/* 到时提醒弹窗 */
.alert-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.alert-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  width: 80%;
  max-width: 600rpx;
  text-align: center;
  animation: popIn 0.3s ease-out;
}
@keyframes popIn {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
.alert-emoji-big {
  font-size: 160rpx;
  margin-bottom: 20rpx;
  animation: bounce 0.6s ease-out infinite alternate;
}
@keyframes bounce {
  from { transform: translateY(0); }
  to { transform: translateY(-10rpx); }
}
.alert-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #C0392B;
  margin-bottom: 12rpx;
}
.alert-subtitle {
  font-size: 28rpx;
  color: #7F8C8D;
  margin-bottom: 32rpx;
}
.alert-actions button {
  width: 100%;
}
