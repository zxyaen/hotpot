.history-page { padding: 30rpx; }
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #8B0000;
}
.clear-btn {
  color: #E74C3C;
  font-size: 28rpx;
  padding: 10rpx;
}
.record-list { display: flex; flex-direction: column; gap: 20rpx; }
.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.record-head {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #7F8C8D;
  margin-bottom: 10rpx;
}
.record-date { font-weight: 500; color: #2C3E50; }
.record-pot {
  font-size: 28rpx;
  color: #C0392B;
  margin-bottom: 10rpx;
}
.record-foods { display: flex; justify-content: space-between; align-items: center; }
.record-foods-emoji { font-size: 36rpx; letter-spacing: 4rpx; }
.record-foods-count { font-size: 24rpx; color: #95A5A6; }
.empty-state { text-align: center; padding: 160rpx 40rpx; }
.empty-emoji { font-size: 120rpx; margin-bottom: 20rpx; }
.empty-title { font-size: 36rpx; font-weight: 600; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #95A5A6; }
