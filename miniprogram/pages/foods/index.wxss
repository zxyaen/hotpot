.foods-page {
  padding: 20rpx;
  padding-bottom: 60rpx;
}

.search-bar {
  margin-bottom: 16rpx;
}
.search-input {
  background: #fff;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.cat-scroll {
  white-space: nowrap;
  margin-bottom: 16rpx;
}
.cat-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
}
.cat-item {
  display: inline-block;
  padding: 12rpx 30rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #7F8C8D;
  white-space: nowrap;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}
.cat-item.active {
  background: linear-gradient(135deg, #C0392B, #8B0000);
  color: #fff;
  font-weight: 600;
}

.food-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 16rpx;
}
.food-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  position: relative;
  transition: transform 0.15s;
}
.food-card:active {
  transform: scale(0.97);
  background: #FFF5E6;
}

.fav-icon {
  position: absolute;
  top: 12rpx;
  right: 16rpx;
  font-size: 36rpx;
  color: #BDC3C7;
  z-index: 2;
  padding: 8rpx;
}
.fav-icon.active {
  color: #F39C12;
}

.food-emoji-big {
  font-size: 72rpx;
  line-height: 1;
  margin-bottom: 12rpx;
}
.food-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 6rpx;
}
.food-time {
  font-size: 24rpx;
  color: #C0392B;
  font-weight: 500;
  margin-bottom: 6rpx;
}
.food-tips {
  font-size: 22rpx;
  color: #95A5A6;
  line-height: 1.3;
  height: 52rpx;
  overflow: hidden;
}

.empty {
  text-align: center;
  color: #95A5A6;
  padding: 100rpx;
}
.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.foods-tip {
  text-align: center;
  color: #95A5A6;
  font-size: 24rpx;
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}

/* 自定义食材卡片样式 */
.custom-food {
  border: 2rpx dashed #C0392B !important;
  background: #FFF8F8 !important;
}
.custom-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  font-size: 18rpx;
  color: #C0392B;
  background: #FFE5E5;
  border-radius: 8rpx;
  padding: 2rpx 8rpx;
  z-index: 2;
}

/* 添加自定义食材卡片 */
.add-card {
  border: 3rpx dashed #C0392B !important;
  background: #FFF8F8 !important;
  opacity: 0.8;
}
.add-card .food-emoji-big {
  font-size: 60rpx;
  color: #C0392B;
}
.add-card .food-name {
  color: #C0392B;
  font-weight: 600;
}
