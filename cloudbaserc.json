{
  "version": "2.0",
  "envId": "{{YOUR_ENV_ID}}",
  "framework": {
    "name": "hotpot-timer-server",
    "plugins": {}
  },
  "cloudrun": {
    "serviceName": "hotpot-timer-server",
    "uploadType": "package",
    "dockerfilePath": "./server/Dockerfile",
    "buildDir": "./server",
    "cpu": 0.25,
    "mem": 256,
    "minNum": 0,
    "maxNum": 2,
    "policyType": "cpu",
    "policyThreshold": 60,
    "containerPort": 3000,
    "envVariables": {
      "NODE_ENV": "production"
    }
  }
}
